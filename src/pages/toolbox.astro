---
// src/pages/toolbox.astro
import { ToolboxPage } from '../components/keystatic/Toolbox/ToolboxPage';
import '../styles/toolbox.css';
import '../styles/toolbox-animations.css';

// 仅在开发模式下可用
const isDev = import.meta.env.DEV;

if (!isDev) {
  return Astro.redirect('/');
}
---

<!DOCTYPE html>

<html lang="zh-CN">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>工具箱 - MyNav 管理后台</title>
</head>

<body>
  <div id="toolbox-root">
    <ToolboxPage client:only="react" />
  </div>
</body>

</html>
