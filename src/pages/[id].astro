---
// src/pages/[id].astro
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar/index.astro';
import SiteCard from '../components/SiteCard/index.astro';
import SearchModal, { SearchTrigger } from '../components/SearchModal.jsx';
import ShareExportModal from '../components/ShareExportModal.jsx';
import ThemePicker from '../components/ThemePicker/index.astro';
import ResourceFilter from '../components/ResourceFilter.astro';
import siteConfig from '../content/site-settings/config.json';
import { getCollection } from 'astro:content'; 
import { LayoutDashboard, Star, Code, Palette, Clapperboard, Headphones, Image, Video, Hammer, Settings, Briefcase, Network, Download, Menu } from 'lucide-react';
import { sortResourcesByStatus } from '../utils/resourceSort';

import GlobalShareButton from '../components/GlobalShareButton.jsx';

// 辅助函数：构建包含页面所有分组、分类和卡片的嵌套树形数据结构
function buildShareTree(groups: any[]) {
  return groups.map((group, groupIdx) => {
    const node = {
      id: `group-${groupIdx}`,
      type: 'group',
      name: group.name,
      children: [] as any[]
    };
    if (group.resources && group.resources.length > 0) {
      node.children.push(...group.resources.map((r: any) => ({ type: 'card', data: r })));
    }
    (group.categories || []).forEach((cat: any, catIdx: number) => {
      const catId = `cat-${groupIdx}-${catIdx}`;
      const catNode = {
        id: catId,
        type: 'category',
        name: cat.name,
        children: [] as any[]
      };
      if (cat.resources && cat.resources.length > 0) {
        catNode.children.push(...cat.resources.map((r: any) => ({ type: 'card', data: r })));
      }
      (cat.tabs || []).forEach((tab: any, tabIdx: number) => {
        const tabId = `pane-${groupIdx}-${catIdx}-${tabIdx}`;
        const tabNode = {
          id: tabId,
          type: 'tab',
          name: tab.tabName,
          children: [] as any[]
        };
        if (tab.list && tab.list.length > 0) {
          tabNode.children.push(...tab.list.map((r: any) => ({ type: 'card', data: r })));
        }
        if (tabNode.children.length > 0) catNode.children.push(tabNode);
      });
      if (catNode.children.length > 0) node.children.push(catNode);
    });
    return node;
  });
}

export const prerender = true;

export async function getStaticPaths() {
  const rawPages = await getCollection('nav-pages');
  const rawGroups = await getCollection('nav-groups');

  const navResources = rawPages.map(page => {
    const currentGroups = rawGroups
       .filter(g => {
         const groupPageId = typeof g.data.pageName === 'object' 
            ? g.data.pageName.id 
            : g.data.pageName;
         return groupPageId === page.id;
       }) 
       .sort((a, b) => {
          const sortA = Number(a.data.pageConfig?.sortPrefix || 10);
          const sortB = Number(b.data.pageConfig?.sortPrefix || 10);
          return sortA - sortB;
       });
    
    return {
      ...page.data,
      id: page.id,
      groups: currentGroups.map(g => g.data)
    };
  }).sort((a, b) => (a.sortOrder || 99) - (b.sortOrder || 99));

  return navResources.map((section) => ({
    params: { id: section.id },
    props: { section, navResources }, 
  }));
}

const { section, navResources } = Astro.props;
const { id } = Astro.params;

// 图标处理
const Icons = { Star, Code, Palette, LayoutDashboard, Clapperboard, Headphones, Image, Video, Hammer, Settings, Briefcase, Network, Download };
const CurrentIcon = section.icon ? (Icons[section.icon] || LayoutDashboard) : LayoutDashboard;
---

<Layout title={`${section.name} - ${siteConfig.title}`}>
  
  <div class="flex min-h-screen w-full">
    <Sidebar navResources={navResources} currentId={id} siteConfig={siteConfig} />
    <div id="sidebar-overlay"></div>

    <main class="layout-transition flex-1 min-w-0 md:ml-[var(--sidebar-width,17rem)] min-h-screen flex flex-col">
      {/* 顶部 Header */}
      <header id="page-header" class="layout-transition fixed top-0 right-0 z-30 flex items-center justify-between px-4 md:px-8 py-4 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-slate-200/50 dark:border-gray-800/50 w-full md:w-[calc(100%-var(--sidebar-width,17rem))] transition-all duration-300">
        
        <div class="flex items-center gap-3 min-w-0">
          <button id="menu-btn" class="p-2 text-slate-600 dark:text-slate-300 bg-white/80 dark:bg-gray-800/80 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 shrink-0 hover:text-brand-600 transition-colors" onclick="if(window.innerWidth < 768) window.toggleSidebarMobile(); else window.toggleSidebarPC();">
            <Menu size={20} />
          </button>
          
          <h1 class="text-xl font-black flex items-center gap-3 text-slate-800 dark:text-white truncate">
            <div class="p-2 bg-brand-50 dark:bg-brand-900/30 rounded-lg text-brand-600 shrink-0"><CurrentIcon size={20} /></div>
            <span class="truncate">{section.name}</span>
          </h1>
        </div>
        
        <div class="flex items-center gap-2 md:gap-3 shrink-0">
          <SearchTrigger client:idle />
          <ResourceFilter />
          <GlobalShareButton client:idle />
          <ThemePicker />
        </div>
      </header>

      {/* 内容区域 */}
      <div transition:name="main-content" class="p-4 pt-24 md:p-8 md:pt-28 space-y-12 w-full max-w-[1440px] mx-auto">
        {(section.groups || []).length === 0 && (
           <div class="text-center text-slate-400 mt-20">暂无内容，请在后台配置分组并关联到此页面。</div>
        )}

        {(section.groups || []).map((group, groupIdx) => (
          <div class="group-wrapper w-full">
            <div id={`group-${groupIdx}`} class="flex items-center gap-3 mb-8 mt-12 first:mt-0 pb-2 border-b border-slate-100 dark:border-slate-800 scroll-mt-28 share-observe-target">
              <h2 class="text-xl font-black text-slate-800 dark:text-slate-100">
                 {group.visualTag && <span class="mr-2">{group.visualTag}</span>}
                 {group.name}
              </h2>
            </div>
            
            <div class="space-y-16 w-full">
              {/* 分组直属资源 */}
              {group.resources && group.resources.length > 0 && (
                <section class="group-resources mb-8 w-full">
                  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 2xl:grid-cols-7 gap-3 md:gap-4 pt-1 w-full">
                    {sortResourcesByStatus(group.resources).map((site) => <SiteCard {...site} />)}
                  </div>
                </section>
              )}

              {/* 子分类渲染 */}
              {(group.categories || []).map((category, catIdx) => {
                 const uniqueId = `${groupIdx}-${catIdx}`;
                 const hasList = category.resources && category.resources.length > 0;
                 const hasTabs = category.tabs && category.tabs.length > 0;
                 if (!hasList && !hasTabs) return null;
                 return (
                    <section id={`cat-${uniqueId}`} class="category-group scroll-mt-28 w-full share-observe-target">
                      <div class="flex flex-wrap items-center justify-start gap-x-6 gap-y-4 mb-8">
                        <h3 class="flex items-center gap-3 text-lg font-bold text-slate-700 dark:text-slate-200 shrink-0">
                          <span class="w-1.5 h-5 bg-brand-600 rounded-full"></span>
                          {category.name}
                        </h3>

                        {/* Tab 按钮 */}
                        {hasTabs && (
                          <div class="flex items-center gap-2">
                            <div class="tab-nav-container relative z-0 flex bg-slate-200/50 dark:bg-slate-800/50 p-1 rounded-full overflow-x-auto no-scrollbar max-w-full isolate">
                              <div class="tab-indicator absolute bg-white dark:bg-slate-700 shadow-sm rounded-full h-[calc(100%-8px)] top-1 transition-all duration-300 ease-[cubic-bezier(0.25,0.1,0.25,1.0)] transform-gpu pointer-events-none"></div>

                              {category.tabs.map((tab: any, tabIdx: number) => (
                                <button
                                  class={`tab-btn relative z-10 px-4 py-1.5 text-xs font-bold rounded-full transition-colors duration-200 whitespace-nowrap focus:outline-none focus:ring-0
                                  ${tabIdx === 0 ? 'text-brand-600 active-tab' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'}`}
                                  data-target={`pane-${uniqueId}-${tabIdx}`}
                                  data-index={tabIdx}
                                >
                                  {tab.tabName}
                                </button>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>

                      <div class="tab-content-wrapper relative z-10 w-full">
                        {/* 直属资源 */}
                        {hasList && (
                          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 2xl:grid-cols-7 gap-3 md:gap-4 pt-1 w-full mb-8">
                            {sortResourcesByStatus(category.resources).map((site) => <SiteCard {...site} />)}
                          </div>
                        )}

                        {/* Tab 内容 */}
                        {hasTabs && (
                          category.tabs.map((tab, tabIdx) => (
                            <div 
                              id={`pane-${uniqueId}-${tabIdx}`} 
                              class={`tab-pane animate-fade-in relative z-20 w-full ${tabIdx !== 0 ? 'hidden' : ''}`}
                            >
                              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 2xl:grid-cols-7 gap-3 md:gap-4 pt-1 w-full">
                                {sortResourcesByStatus(tab.list || []).map((site) => <SiteCard {...site} />)}
                              </div>
                            </div>
                          ))
                        )}
                      </div>
                    </section>
                 )
              })}
            </div>
          </div>
        ))}
        
        <footer class="mt-20 py-10 text-center text-[13px] text-slate-400 border-t border-slate-200/50 dark:border-gray-800/50">
          <p>Made with ❤️ by {siteConfig.author} © {new Date().getFullYear()}</p>
        </footer>
      </div>
    </main>
  </div>

  <SearchModal client:idle />
  {/* 分享导出模态框 */}
  <ShareExportModal client:idle />
</Layout>

<script define:vars={{ shareTree: buildShareTree(section.groups || []), shareTitle: section.name }}>
  window.__PAGE_SHARE_TREE__ = shareTree;
  window.__PAGE_SHARE_TITLE__ = shareTitle;
</script>

{/* IntersectionObserver 页面区块定位监听 */}
<script>
  function initShareObserver() {
    const targets = document.querySelectorAll('.share-observe-target');
    if (!targets.length) return;

    // 获取当前在视口内的元素
    const observer = new IntersectionObserver((entries) => {
      // 找出当前可见比例最大的元素
      let maxRatio = 0;
      let activeId = null;
      
      entries.forEach(entry => {
        if (entry.isIntersecting && entry.intersectionRatio > maxRatio) {
          maxRatio = entry.intersectionRatio;
          activeId = entry.target.id;
        }
      });
      
      if (activeId) {
        (window as any).__ACTIVE_SHARE_ID__ = activeId;
      }
    }, {
      rootMargin: '-10% 0px -40% 0px', // 关注偏上半部分的屏幕
      threshold: [0, 0.25, 0.5, 0.75, 1]
    });

    targets.forEach(el => observer.observe(el));
    
    // 如果没有被覆盖时设置默认第一个为 active
    if (!(window as any).__ACTIVE_SHARE_ID__ && targets[0]) {
      (window as any).__ACTIVE_SHARE_ID__ = targets[0].id;
    }
  }

  document.addEventListener('astro:page-load', initShareObserver);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareObserver);
  } else {
    initShareObserver();
  }
</script>
