---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/mdx/Container.astro';
import '../../styles/mdx.css';

// 🔥 关键修复：显式声明为静态预渲染
// 加上这行代码，彻底消除 "NoAdapterInstalled" 报错的可能性
export const prerender = true;

// 1. 生成路径
export async function getStaticPaths() {
  const guideEntries = await getCollection('guides');
  return guideEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

// 2. 获取内容
const { entry } = Astro.props;
const { Content } = await entry.render();
const title = entry.data.title || entry.id; // 兜底标题
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={title}>
  <div class="max-w-4xl mx-auto px-6 py-12 min-h-screen">
    <a href={`${base}/home`} class="inline-flex items-center text-sm text-blue-600 mb-8 hover:underline">
      ← 返回导航首页
    </a>

    <article class="prose prose-slate dark:prose-invert lg:prose-lg mx-auto bg-white dark:bg-gray-800 p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-700">
      <h1 class="mb-4">{title}</h1>
      <div class="text-sm text-gray-400 mb-8 border-b border-gray-100 dark:border-gray-700 pb-4">
        发布时间：{entry.data.date?.toISOString().split('T')[0]}
      </div>
      
      {/* 🔥 注入组件，确保 MDX 中的 <Container> 和 <GitHubAlert> 标签能被正确解析 */}
      <Content components={{ Container, GitHubAlert: Container }} />
    </article>
  </div>
</Layout>