---
// src/components/SiteCard/index.astro
import { BookOpen, Info } from 'lucide-react';
import { marked } from 'marked';
import { getBadges } from './utils';
import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

// 引入样式
import './site-card.css';

// cn 工具函数
const cn = (...inputs: ClassValue[]) => twMerge(clsx(inputs));

// 接收 Props
const { title, name, url, icon, desc, detail, official_site, hide_badges = [], guide_id, status = 'ok' } = Astro.props;

const targetUrl = url || official_site || '#';

const displayTitle = title || name;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 1. 图标逻辑 - 修复：添加 base 前缀到本地图标路径
const localFallback = `${base}/favicon.svg`;
const finalIcon = (icon && icon.includes('/images/')) ? `${base}${icon}` : localFallback;


// 2. 徽章逻辑
const badges = getBadges(url, hide_badges);

// 3. 详情内容逻辑 (纯 Markdown 模式)
const hasDetailContent = detail && detail.trim().length > 0;

// 计算 hasPopup
const hasPopup = !!(hasDetailContent || (badges && badges.length > 0));

// 4. 预先解析 Markdown 为 HTML
let markdownHtml = '';
if (hasDetailContent) {
  markdownHtml = marked.parse(detail) as string;
}

// 简化 cardId 生成
const cardId = `site-${Math.random().toString(36).substr(2, 9)}`;

// 定义图标尺寸
const ICON_SIZE = 48;

// 根据状态计算样式
const statusStyles = {
  ok: '',
  stale: 'grayscale-[30%] opacity-70 hover:grayscale-0 hover:opacity-100',
  '官网失效': 'grayscale-[60%] opacity-50 pointer-events-none',
  'github已归档': 'grayscale-[30%] opacity-70 hover:grayscale-0 hover:opacity-100',
  'github仓库已失效': 'grayscale-[60%] opacity-50 pointer-events-none',
  '网站失效': 'grayscale-[60%] opacity-50 pointer-events-none',
  '网站超时': 'grayscale-[40%] opacity-60 hover:grayscale-0 hover:opacity-100',
};

const cardWrapperStyles = cn(
  'site-card-wrapper group relative w-full h-full',
  status !== 'ok' && `resource-${status}`
);

const cardLinkStyles = cn(
  'flex items-center justify-between w-full h-full py-1.5 pl-[3px] pr-0 md:py-3 md:pl-3 md:pr-1',
  'bg-white/70 dark:bg-gray-800/60 backdrop-blur-xl rounded-xl',
  'border border-white/60 dark:border-gray-700/50',
  'transition-all duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]',
  'group-hover:bg-white/95 dark:group-hover:bg-gray-800/95',
  'group-hover:border-brand-500/30 dark:group-hover:border-brand-400/30',
  'group-hover:shadow-xl group-hover:shadow-brand-600/10',
  'group-hover:ring-1 group-hover:ring-brand-500/20',
  'overflow-hidden',
  statusStyles[status as keyof typeof statusStyles] || ''
);

const titleStyles = cn(
  'font-heading font-bold text-[14px] text-slate-800 dark:text-slate-100 truncate mb-0.5 text-left group-hover:text-brand-600 transition-colors duration-200',
  (status === '官网失效' || status === 'github仓库已失效' || status === '网站失效') && 'line-through'
);
---

<div class={cardWrapperStyles} data-status={status}>
  {/* 流光边框容器 */}
  <div class="neon-border" aria-hidden="true"></div>
  <a href={targetUrl} target="_blank" class={cardLinkStyles}>
    <div class="flex items-center flex-1 min-w-0 mr-0 md:mr-0.5 overflow-hidden">
      <div class="relative flex-shrink-0 mr-1 md:mr-1.5 w-10 h-10 flex items-center justify-center">
        {/* 背景光晕层 - icon-glow */}
        <div class="icon-glow absolute inset-0 z-0 transition-all duration-500 ease-out opacity-0 group-hover:opacity-50 group-hover:scale-150 filter blur-lg saturate-150 pointer-events-none transform-gpu">
          <img 
            src={finalIcon} 
            alt="" 
            width={ICON_SIZE} 
            height={ICON_SIZE} 
            loading="lazy"       
            decoding="async" 
            class="w-full h-full object-contain" 
          />
        </div>
        
        {/* 核心图标层 - icon-container */}
        <div class="icon-container relative z-10 w-10 h-10 rounded-lg bg-white/80 dark:bg-gray-700/90 shadow-sm flex items-center justify-center border border-gray-100 dark:border-gray-600 group-hover:scale-105 group-hover:shadow-md transition-all duration-300">
          <img 
            id={cardId}
            src={finalIcon}
            alt={displayTitle} 
            width={24}
            height={24}
            loading="lazy"        
            decoding="async" 
            class="w-8 h-8 object-contain transition-transform duration-300" 
          />
        </div>
      </div>
      
      <div class={cn("flex-1 min-w-0 relative z-20 overflow-hidden flex flex-col", !desc && "justify-center")}>
        <h3 class={titleStyles}>
          {displayTitle}
        </h3>
        {desc && (
          <div class="desc-wrapper relative w-full flex items-center overflow-hidden opacity-80 group-hover:opacity-100 transition-opacity h-[1.25em] -mt-0.5 pt-0.5">
            <p class="desc-text font-body text-[12px] text-slate-400 dark:text-slate-500 leading-none whitespace-nowrap block max-w-none">
              {desc}
            </p>
          </div>
        )}
      </div>
    </div>

    {/* 右侧按钮区域 - action-buttons */}
    <div class="action-buttons shrink-0 pl-0 md:pl-1 border-l border-slate-100 dark:border-slate-700/50 transition-all duration-200 z-20">
      {hasPopup && (
        <button type="button" class="info-btn p-1 rounded-md text-slate-400 hover:text-brand-600 hover:bg-brand-50 dark:hover:bg-gray-700 transition-all flex items-center justify-center" title="详情">
          <Info size={14} />
        </button>
      )}
      {guide_id && (
        <button onclick={`event.preventDefault(); event.stopPropagation(); window.open('${base}/guide/${guide_id}', '_blank');`} class="guide-btn p-1 rounded-md text-brand-600 hover:bg-brand-600 hover:text-white transition-all flex items-center justify-center" title="教程">
          <BookOpen size={14} strokeWidth={2.5} />
        </button>
      )}
    </div>
  </a>
  </a>

  {/* 弹窗区域 */}
  {hasPopup && (
    <div class="tooltip-source hidden">
      <div class="relative z-10">
        <div class="text-[11px] font-black text-brand-600 dark:text-brand-400 mb-2 flex items-center gap-2 uppercase tracking-widest font-body">
          <span class="w-1.5 h-3 bg-brand-600 rounded-sm"></span>详情
        </div>
        {badges.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-2 border-b border-slate-100 dark:border-slate-800 pb-2">
            {badges.map(b => <img data-src={b.src} alt={b.alt} class="h-4 min-w-16 rounded-sm" />)}
          </div>
        )}
        {hasDetailContent && (
          <div class="detail-markdown text-[13px] text-slate-700 dark:text-slate-300 leading-relaxed break-words">
            <div set:html={markdownHtml} />
          </div>
        )}
      </div>
    </div>
  )}
</div>

<script>
  import { initSiteCard } from './client';
  
  // 确保在每次 Astro 页面过渡（Client-side navigation）及初始加载后全量绑事件
  document.addEventListener('astro:page-load', initSiteCard);
  document.addEventListener('astro:after-swap', initSiteCard);
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSiteCard);
  } else {
    initSiteCard();
  }
</script>
