---
// Toast notification component
---

<div id="toast-container" class="fixed bottom-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

<script>
  // Toast notification system
  class ToastManager {
    private container: HTMLElement | null = null;
    private static instance: ToastManager;

    static getInstance() {
      if (!ToastManager.instance) {
        ToastManager.instance = new ToastManager();
      }
      return ToastManager.instance;
    }

    private getContainer() {
      if (!this.container) {
        this.container = document.getElementById('toast-container');
      }
      return this.container;
    }

    show(message: string, type: 'success' | 'error' | 'info' | 'warning' = 'info', duration = 3000) {
      const container = this.getContainer();
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = `
        pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg
        transform transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)]
        translate-y-4 opacity-0
        ${this.getTypeStyles(type)}
      `;

      const icons = {
        success: `<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`,
        error: `<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>`,
        warning: `<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>`,
        info: `<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
      };

      toast.innerHTML = `
        <span class="flex-shrink-0">${icons[type]}</span>
        <span class="text-sm font-medium">${message}</span>
      `;

      container.appendChild(toast);

      // Animate in
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-4', 'opacity-0');
      });

      // Auto remove
      setTimeout(() => {
        toast.classList.add('translate-y-4', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }, duration);
    }

    private getTypeStyles(type: string): string {
      const styles: Record<string, string> = {
        success: 'bg-emerald-500 text-white',
        error: 'bg-red-500 text-white',
        warning: 'bg-amber-500 text-white',
        info: 'bg-slate-700 text-white dark:bg-slate-600'
      };
      return styles[type] || styles.info;
    }
  }

  // Expose to window
  (window as any).toast = {
    success: (msg: string, duration?: number) => ToastManager.getInstance().show(msg, 'success', duration),
    error: (msg: string, duration?: number) => ToastManager.getInstance().show(msg, 'error', duration),
    warning: (msg: string, duration?: number) => ToastManager.getInstance().show(msg, 'warning', duration),
    info: (msg: string, duration?: number) => ToastManager.getInstance().show(msg, 'info', duration)
  };
</script>
